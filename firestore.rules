rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /clinics/{clinicId} {
      // Allow public read for booking page
      allow read: if true;
      allow write: if request.auth != null;
      
      match /patients/{patientId} {
        allow read: if request.auth != null;
        // Allow public create for booking page, auth for other writes
        allow create: if true;
        allow update, delete: if request.auth != null;
      }
      
      match /appointments/{appointmentId} {
        allow read: if request.auth != null;
        // Allow public create for booking page, auth for other writes
        allow create: if true;
        allow update, delete: if request.auth != null;
      }
      
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /invites/{inviteId} {
      allow read: if true; // anyone can read to verify token
      allow write: if request.auth != null; // only logged in users (super admin) can create
    }
  }
}
